# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Bootstrap admin (one-time promotion secret)
BOOTSTRAP_ADMIN_SECRET=meta-bootstrap-2026

# Google Service Account (JSON key downloaded from Google Cloud Console)
# Either paste the JSON inline OR point to a file path.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=google-credentials.json

# The Google Spreadsheet ID that holds all sheets (from its URL)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Google Drive folder for uploaded documents (create an empty folder and paste its ID)
GOOGLE_DRIVE_FOLDER_ID=

# SMTP / Gmail API for outbound email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=META ONLINE SERVICE <no-reply@metaonlineservice.com>
